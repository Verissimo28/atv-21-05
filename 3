#include <stdio.h>

struct No {
    int dado;
    struct No *proximo;
};

int buscarCidadao(struct No *head, int cpf_buscado) {
    struct No *atual = head;

    while (atual != NULL) {

        if (atual->dado == cpf_buscado) {
            return 1;
        }

        atual = atual->proximo;
    }

    return 0;
}
